<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SSO Demo - Main Portal</title>
    <script src="https://alcdn.msauth.net/browser/2.38.2/js/msal-browser.min.js"></script>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Segoe UI', Tahoma, sans-serif; background: #f0f2f5; color: #333; }
        .header { background: linear-gradient(135deg, #0078d4, #005a9e); color: #fff; padding: 24px 40px; }
        .header h1 { font-size: 1.8rem; } .header p { opacity: 0.85; margin-top: 4px; }
        .container { max-width: 960px; margin: 32px auto; padding: 0 20px; }
        .card { background: #fff; border-radius: 10px; padding: 24px; margin-bottom: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
        .app-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-top: 16px; }
        .app-link { display: block; text-align: center; padding: 32px 16px; background: #f8f9fa; border-radius: 8px;
                    text-decoration: none; color: #0078d4; border: 2px solid transparent; transition: all 0.2s; }
        .app-link:hover { border-color: #0078d4; background: #e8f4fd; transform: translateY(-2px); }
        .app-link h3 { margin-bottom: 8px; }
        .btn { background: #0078d4; color: #fff; border: none; padding: 10px 24px; border-radius: 6px;
               cursor: pointer; font-size: 14px; margin: 4px; transition: background 0.2s; }
        .btn:hover { background: #106ebe; }
        .btn-danger { background: #d13438; } .btn-danger:hover { background: #a4262c; }
        .btn-secondary { background: #6c757d; } .btn-secondary:hover { background: #5a6268; }
        .btn-token { background: #8b5cf6; } .btn-token:hover { background: #7c3aed; }
        .user-bar { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
        .status { padding: 10px 16px; border-radius: 6px; font-weight: 500; }
        .signed-in { background: #dff6dd; color: #107c10; }
        .signed-out { background: #fed9cc; color: #d83b01; }
        pre { background: #1e1e1e; color: #d4d4d4; padding: 16px; border-radius: 8px; overflow-x: auto;
              margin-top: 12px; font-size: 13px; max-height: 400px; }
        .groups-list { margin-top: 8px; }
        .groups-list span { display: inline-block; background: #e8f4fd; color: #0078d4;
             padding: 4px 10px; border-radius: 12px; font-size: 12px; margin: 2px; }
        .tab-bar { display: flex; gap: 4px; margin-bottom: 12px; }
        .tab { padding: 8px 16px; border: none; background: #e0e0e0; border-radius: 6px 6px 0 0;
               cursor: pointer; font-size: 13px; } .tab.active { background: #1e1e1e; color: #d4d4d4; }
        .api-section { margin-top: 16px; }
        .api-section h3 { margin-bottom: 8px; font-size: 1rem; color: #555; }
        hr { border: none; border-top: 1px solid #e0e0e0; margin: 12px 0; }
    </style>
</head>
<body>
    <div class="header">
        <h1>SSO Demo &mdash; Main Portal</h1>
        <p>Single Sign-On across multiple applications with Entra ID</p>
    </div>

    <div class="container">
        <!-- Auth Card -->
        <div class="card">
            <div class="user-bar">
                <div class="status signed-out" id="status">Not signed in</div>
                <button class="btn" id="loginBtn" onclick="login()">Sign In</button>
                <button class="btn btn-token" id="tokenBtn" onclick="showToken()" style="display:none">&#128273; See My JWT Token</button>
                <button class="btn btn-danger" id="logoutBtn" onclick="logout()" style="display:none">Sign Out</button>
            </div>
            <div id="groups-container" style="display:none" class="groups-list"></div>
            <div id="roles-container" style="display:none" class="groups-list"></div>
        </div>

        <!-- App Navigation -->
        <div class="card">
            <h2>Applications</h2>
            <p>Click any app below &mdash; SSO means you won't need to sign in again.</p>
            <div class="app-grid">
                <a href="/app1/" class="app-link"><h3>&#128230; Orders App</h3><p>Manage orders</p></a>
                <a href="/app2/" class="app-link"><h3>&#128101; Users App</h3><p>Manage users</p></a>
                <a href="/app3/" class="app-link"><h3>&#128722; Products App</h3><p>Manage products</p></a>
            </div>
        </div>

        <!-- JWT Token Viewer -->
        <div class="card" id="token-card" style="display:none">
            <h2>&#128273; JWT Token Inspector</h2>
            <p>Your decoded ID token from Entra ID, including group memberships:</p>
            <div class="tab-bar">
                <button class="tab active" onclick="showTab('decoded')">Decoded</button>
                <button class="tab" onclick="showTab('raw')">Raw Token</button>
            </div>
            <pre id="token-decoded"></pre>
            <pre id="token-raw" style="display:none;word-break:break-all;white-space:pre-wrap"></pre>
        </div>

        <!-- API Testing -->
        <div class="card">
            <h2>Backend API Testing</h2>
            <p>Compare APIs through both ingress paths (AGC vs Traefik):</p>

            <div class="api-section">
                <h3>Cluster 1 &mdash; App Gateway for Containers (AGC)</h3>
                <button class="btn" onclick="callApi('/api/agc/orders')">Orders</button>
                <button class="btn" onclick="callApi('/api/agc/users')">Users</button>
                <button class="btn" onclick="callApi('/api/agc/products')">Products</button>
            </div>
            <hr>
            <div class="api-section">
                <h3>Cluster 2 &mdash; Traefik + Internal LB</h3>
                <button class="btn btn-secondary" onclick="callApi('/api/traefik/orders')">Orders</button>
                <button class="btn btn-secondary" onclick="callApi('/api/traefik/users')">Users</button>
                <button class="btn btn-secondary" onclick="callApi('/api/traefik/products')">Products</button>
            </div>

            <pre id="api-output">// API response will appear here</pre>
        </div>
    </div>

    <script>
        const msalConfig = {
            auth: {
                clientId: "${client_id}",
                authority: "https://login.microsoftonline.com/${tenant_id}",
                redirectUri: "${base_url}/"
            },
            cache: { cacheLocation: "localStorage", storeAuthStateInCookie: true }
        };
        const msalInstance = new msal.PublicClientApplication(msalConfig);

        msalInstance.handleRedirectPromise().then(handleResponse).catch(console.error);

        function handleResponse(resp) {
            const account = resp ? resp.account : msalInstance.getAllAccounts()[0];
            if (account) showUser(account);
        }

        function login() {
            msalInstance.loginRedirect({ scopes: ["openid", "profile", "email"] });
        }
        function logout() {
            msalInstance.logoutRedirect();
        }

        function showUser(account) {
            document.getElementById("status").className = "status signed-in";
            document.getElementById("status").textContent = "Signed in: " + account.name + " (" + account.username + ")";
            document.getElementById("loginBtn").style.display = "none";
            document.getElementById("tokenBtn").style.display = "inline-block";
            document.getElementById("logoutBtn").style.display = "inline-block";
            const claims = account.idTokenClaims;
            // Show groups
            if (claims && claims.groups && claims.groups.length) {
                const container = document.getElementById("groups-container");
                container.style.display = "block";
                container.innerHTML = "<strong>&#128101; Groups:</strong> " +
                    claims.groups.map(g => "<span>" + g + "</span>").join("");
            } else {
                const container = document.getElementById("groups-container");
                container.style.display = "block";
                container.innerHTML = "<strong>&#128101; Groups:</strong> <em>No groups found in token. Assign user to an Entra security group.</em>";
            }
            // Show roles
            if (claims && claims.roles && claims.roles.length) {
                const container = document.getElementById("roles-container");
                container.style.display = "block";
                container.innerHTML = "<strong>&#127919; Roles:</strong> " +
                    claims.roles.map(r => "<span style='background:#fef3c7;color:#92400e'>" + r + "</span>").join("");
            } else {
                const container = document.getElementById("roles-container");
                container.style.display = "block";
                container.innerHTML = "<strong>&#127919; Roles:</strong> <em>No app roles assigned. Assign via Enterprise App &gt; Users and groups.</em>";
            }
        }

        function showToken() {
            const accounts = msalInstance.getAllAccounts();
            if (!accounts.length) return;
            const account = accounts[0];
            const claims = account.idTokenClaims;
            const rawToken = msalInstance.getAccountByHomeId(account.homeAccountId);
            // Decode the cached ID token from localStorage
            const keys = Object.keys(localStorage);
            let idToken = "";
            for (const k of keys) {
                if (k.includes("idtoken")) {
                    try { const t = JSON.parse(localStorage.getItem(k)); if (t.secret) idToken = t.secret; } catch(e) {}
                }
            }
            document.getElementById("token-card").style.display = "block";
            document.getElementById("token-decoded").textContent = JSON.stringify(claims, null, 2);
            document.getElementById("token-raw").textContent = idToken || "(token not found in cache)";
            document.getElementById("token-card").scrollIntoView({ behavior: "smooth" });
        }

        function showTab(tab) {
            document.querySelectorAll(".tab").forEach(t => t.classList.remove("active"));
            if (tab === "decoded") {
                document.getElementById("token-decoded").style.display = "block";
                document.getElementById("token-raw").style.display = "none";
                event.target.classList.add("active");
            } else {
                document.getElementById("token-decoded").style.display = "none";
                document.getElementById("token-raw").style.display = "block";
                event.target.classList.add("active");
            }
        }

        async function callApi(endpoint) {
            const accounts = msalInstance.getAllAccounts();
            if (!accounts.length) { alert("Please sign in first"); return; }
            document.getElementById("api-output").textContent = "Loading...";
            try {
                const token = await msalInstance.acquireTokenSilent({
                    scopes: ["${client_id}/.default"],
                    account: accounts[0]
                });
                const res = await fetch(endpoint, {
                    headers: { "Authorization": "Bearer " + token.accessToken }
                });
                const data = await res.json();
                document.getElementById("api-output").textContent = JSON.stringify(data, null, 2);
            } catch (err) {
                document.getElementById("api-output").textContent = "Error: " + err.message;
            }
        }
    </script>
</body>
</html>
